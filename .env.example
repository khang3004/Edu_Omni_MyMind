# --- Device Configuration ---
# Force a specific device: "cuda", "mps", "cpu", or "auto" (default)
EDUMIND_DEVICE=auto

# --- ASR (Automatic Speech Recognition) ---
# Whisper model size: "tiny", "base", "small", "medium", "large"
# "tiny" is recommended for CPU (~75MB). "base" for better accuracy (~140MB).
EDUMIND_WHISPER_MODEL=tiny

# --- Embedding Model (for RAG) ---
# Sentence-Transformers model for embedding document chunks
EDUMIND_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# Neo4j Database Config
# Use bolt://localhost:7687 for local host development, and bolt://neo4j:7687 inside Docker
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=omni_ips_password

# Qdrant Vector DB Config
# Use localhost for local host development, and qdrant inside Docker
QDRANT_HOST=localhost
QDRANT_PORT=6333
# --- Translation Model ---
# HuggingFace seq2seq model for Vi-En translation
# Set to "none" to use rule-based fallback (faster, no download)
EDUMIND_TRANSLATION_MODEL=none

# --- Qdrant Vector Database ---
# Mode: "memory" (in-process, no server needed) or "server" (external Qdrant)
QDRANT_MODE=memory

# If QDRANT_MODE=server, configure connection:
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Qdrant collection name for RAG documents
QDRANT_COLLECTION_NAME=edumind_documents

#Hugging Face access token
HF_TOKEN=

# LLM API Keys
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=


# Model-Agnostic LLM Configuration
# Supported Providers: google, openai, groq, ollama, custom
LLM_PROVIDER=google
LLM_MODEL=gemma-4-31b-it
LLM_BASE_URL=
LLM_API_KEY_PREFIX=GEMINI_API_KEY_

# Model-Agnostic Embedding Configuration
# Supported Providers: local, openai, ollama, custom
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY_PREFIX=


# --- Streamlit Configuration ---
# Server port (default: 8501)
STREAMLIT_SERVER_PORT=8501

# --- Label Studio & ML Backend Configuration ---
# Admin login credentials for Label Studio UI
LABEL_STUDIO_USERNAME=admin@edumind.local
LABEL_STUDIO_PASSWORD=edumind_admin_2024

# The public URL of the Label Studio UI (Must include http:// or https://)
LABEL_STUDIO_HOST=http://localhost:8080

# Port settings
LABEL_STUDIO_PORT=8080
ML_BACKEND_PORT=9090

# Local file serving configuration (allows Label Studio to access host audio/PDFs)
LABEL_STUDIO_LOCAL_FILES_SERVING_ENABLED=true
LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=data

# Path to the active-learning gold-standard corpus JSONL
CORPUS_JSONL_PATH=data/processed/corpus.jsonl

# -----------------------------------------------------------------------
# Corpus Augmentation LLM (scripts/build_vietmix_corpus.py)
# -----------------------------------------------------------------------
# Provider: groq | google | openai
# Groq is recommended — generous free tier, no flash-quota burnout.
#
# Groq open-source models:
#   qwen/qwen3-32b                        (Alibaba — strong instruction following)
#   llama-3.3-70b-versatile               (Meta — best quality, RECOMMENDED)
#   llama-3.1-8b-instant                  (Meta — fastest, high RPM)
#   meta-llama/llama-4-scout-17b-16e-inst (Meta Llama 4 Scout)
#   openai/gpt-oss-120b                   (OpenAI OSS — highest quality)
#   openai/gpt-oss-20b                    (OpenAI OSS — fast)
#   groq/compound                         (Groq compound)
#   groq/compound-mini
#
# Can also override at runtime:
#   uv run python scripts/build_vietmix_corpus.py --provider groq --model qwen/qwen3-32b
CORPUS_LLM_PROVIDER=groq
CORPUS_LLM_MODEL=llama-3.3-70b-versatile
