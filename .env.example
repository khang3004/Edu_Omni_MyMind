# ==============================================================================
# EduMIND — Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# DO NOT commit .env to version control!
# ==============================================================================

# --- Device Configuration ---
# Force a specific device: "cuda", "mps", "cpu", or "auto" (default)
EDUMIND_DEVICE=auto

# --- ASR (Automatic Speech Recognition) ---
# Whisper model size: "tiny", "base", "small", "medium", "large"
# "tiny" is recommended for CPU (~75MB). "base" for better accuracy (~140MB).
EDUMIND_WHISPER_MODEL=tiny

# --- Embedding Model (for RAG) ---
# Sentence-Transformers model for embedding document chunks
EDUMIND_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Translation Model ---
# HuggingFace seq2seq model for Vi-En translation
# Set to "none" to use rule-based fallback (faster, no download)
EDUMIND_TRANSLATION_MODEL=none

# --- Qdrant Vector Database ---
# Mode: "memory" (in-process, no server needed) or "server" (external Qdrant)
QDRANT_MODE=memory

# If QDRANT_MODE=server, configure connection:
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Qdrant collection name for RAG documents
QDRANT_COLLECTION_NAME=edumind_documents

# --- Optional: LLM API for RAG Answer Generation ---
# API Keys
GEMINI_API_KEY_1=your_gemini_api_key
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

GROQ_API_KEY_1=your_grod_api_key
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# Model-Agnostic LLM Configuration (LangChain Integration)
# Supported Providers: openai, ollama, groq, google
LLM_PROVIDER=google
LLM_MODEL=gemma-4-31b-it


# --- Streamlit Configuration ---
# Server port (default: 8501)
STREAMLIT_SERVER_PORT=8501
